<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_widget_quick_actions"
    android:gravity="center"
    android:orientation="vertical"
    android:paddingStart="14dp"
    android:paddingTop="8dp"
    android:paddingEnd="14dp"
    android:paddingBottom="8dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/quick_action_tile_invoice"
            android:layout_width="0dp"
            android:layout_height="82dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="@string/quick_action_cd_new_invoice"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_widget_quick_action_tile"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/quick_action_icon_invoice"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_quick_action_invoice" />

                <TextView
                    android:id="@+id/quick_action_label_invoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/quick_action_label_invoice"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/quick_action_subtitle_invoice"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/quick_action_subtitle_new_invoice"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/quick_action_tile_expense"
            android:layout_width="0dp"
            android:layout_height="82dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="@string/quick_action_cd_add_expense"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_widget_quick_action_tile"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/quick_action_icon_expense"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_quick_action_expense" />

                <TextView
                    android:id="@+id/quick_action_label_expense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/quick_action_label_expense"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/quick_action_subtitle_expense"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/quick_action_subtitle_add_expense"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:baselineAligned="false"
        android:orientation="horizontal">

        <FrameLayout
            android:id="@+id/quick_action_tile_product"
            android:layout_width="0dp"
            android:layout_height="82dp"
            android:layout_marginEnd="6dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="@string/quick_action_cd_add_product"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_widget_quick_action_tile"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/quick_action_icon_product"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_quick_action_product" />

                <TextView
                    android:id="@+id/quick_action_label_product"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/quick_action_label_product"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/quick_action_subtitle_product"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/quick_action_label_product_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/quick_action_tile_customer"
            android:layout_width="0dp"
            android:layout_height="82dp"
            android:layout_marginStart="6dp"
            android:layout_weight="1"
            android:clickable="true"
            android:contentDescription="@string/quick_action_cd_new_customer"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_widget_quick_action_tile"
                android:gravity="center"
                android:importantForAccessibility="no"
                android:orientation="vertical"
                android:padding="4dp">

                <ImageView
                    android:id="@+id/quick_action_icon_customer"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:importantForAccessibility="no"
                    android:src="@drawable/ic_quick_action_customer" />

                <TextView
                    android:id="@+id/quick_action_label_customer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/quick_action_label_customer"
                    android:textColor="@color/text_primary"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/quick_action_subtitle_customer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:importantForAccessibility="no"
                    android:includeFontPadding="false"
                    android:maxLines="1"
                    android:text="@string/quick_action_subtitle_new_customer"
                    android:textColor="@color/text_secondary"
                    android:textSize="9sp" />
            </LinearLayout>
        </FrameLayout>
    </LinearLayout>
</LinearLayout>
