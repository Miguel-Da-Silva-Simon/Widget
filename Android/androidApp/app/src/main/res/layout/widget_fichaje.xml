<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_widget_screen"
    android:orientation="vertical"
    android:paddingStart="12dp"
    android:paddingTop="10dp"
    android:paddingEnd="12dp"
    android:paddingBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/widget_brand_icon"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="center_vertical"
            android:importantForAccessibility="no"
            android:scaleType="fitCenter"
            android:src="@drawable/widget_brand_icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:text="@string/widget_title"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="1dp"
                android:ellipsize="end"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="Practicas"
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_return_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="6dp"
            android:ellipsize="end"
            android:gravity="center_vertical|end"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <FrameLayout
            android:id="@+id/widget_btn_profile"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:clickable="true"
            android:contentDescription="@string/widget_cd_profile_photo"
            android:focusable="true">

            <ImageView
                android:id="@+id/widget_profile_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_widget_profile_avatar"
                android:clipToOutline="true"
                android:padding="2dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile_placeholder" />
        </FrameLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_timer_block"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_timer_capsule"
        android:baselineAligned="false"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingTop="4dp"
        android:paddingEnd="6dp"
        android:paddingBottom="4dp">

        <LinearLayout
            android:id="@+id/widget_timer_panel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:minHeight="40dp"
            android:orientation="horizontal"
            android:padding="10dp">

            <ImageView
                android:id="@+id/widget_status_dot"
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/bg_dot_gray"
                android:importantForAccessibility="no"
                android:scaleType="fitXY" />

            <Chronometer
                android:id="@+id/widget_chronometer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="7dp"
                android:fontFamily="monospace"
                android:includeFontPadding="false"
                android:textColor="@color/text_primary"
                android:textSize="19sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/widget_action_group"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="2dp"
            android:paddingTop="2dp"
            android:paddingEnd="2dp"
            android:paddingBottom="2dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:id="@+id/widget_btn_primary"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:clickable="true"
                    android:contentDescription="@string/widget_cd_primary"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/widget_icon_primary"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_action_button_disabled"
                        android:padding="5dp"
                        android:scaleType="fitCenter" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/widget_btn_break"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="3dp"
                    android:clickable="true"
                    android:contentDescription="@string/widget_cd_descanso"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/widget_icon_break"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_action_button_disabled"
                        android:padding="5dp"
                        android:scaleType="fitCenter" />
                </FrameLayout>

                <FrameLayout
                    android:id="@+id/widget_btn_meal"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="3dp"
                    android:clickable="true"
                    android:contentDescription="@string/widget_cd_comida"
                    android:focusable="true">

                    <ImageView
                        android:id="@+id/widget_icon_meal"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/bg_action_button_disabled"
                        android:padding="5dp"
                        android:scaleType="fitCenter" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
